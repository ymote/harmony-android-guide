+static int dexPtrToHandle(DexOrJar* p) {
+    if (p == NULL) return 0;
+    int h = sNextDexHandle++;
+    if (h >= DEX_MAX_HANDLES) { ALOGE("DexFile handle table full"); dvmAbort(); }
+    sDexHandles[h] = p;
+    return h;
