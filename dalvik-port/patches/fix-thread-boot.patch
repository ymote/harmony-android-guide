+    /* Initialize System.out/err with DirectPrintStream (native I/O) */
+    {
+        ClassObject* dpsCls = dvmFindSystemClassNoInit("Ljava/io/DirectPrintStream;");
+        if (dpsCls) {
+            // Create DirectPrintStream(1) for stdout
+            Object* psOut = dvmAllocObject(dpsCls, ALLOC_DEFAULT);
+            if (psOut) {
+                InstField* fdField = dvmFindInstanceFieldHier(dpsCls, "fd", "I");
+                if (fdField) dvmSetFieldInt(psOut, fdField->byteOffset, 1);
+                
+                StaticField* sysOut = dvmFindStaticField(gDvm.classJavaLangSystem, "out", "Ljava/io/PrintStream;");
+                if (sysOut) { dvmSetStaticFieldObject(sysOut, psOut); ALOGW("System.out = DirectPrintStream(1)"); }
+                dvmReleaseTrackedAlloc(psOut, NULL);
+            }
+            // Create DirectPrintStream(2) for stderr
+            Object* psErr = dvmAllocObject(dpsCls, ALLOC_DEFAULT);
+            if (psErr) {
+                InstField* fdField = dvmFindInstanceFieldHier(dpsCls, "fd", "I");
+                if (fdField) dvmSetFieldInt(psErr, fdField->byteOffset, 2);
+                
+                StaticField* sysErr = dvmFindStaticField(gDvm.classJavaLangSystem, "err", "Ljava/io/PrintStream;");
