+        InstField* tr = dvmFindInstanceFieldHier(gDvm.classJavaLangThreadGroup, "threadRefs", "Ljava/util/List;");
+        if (tr) {
+            ClassObject* alCls = dvmFindSystemClassNoInit("Ljava/util/ArrayList;");
+            if (alCls) {
+                Object* list = dvmAllocObject(alCls, ALLOC_DEFAULT);
